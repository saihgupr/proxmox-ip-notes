#!/bin/bash

# Arguments: MODE ID TYPE CMD
# Manual Mode: (no args) -> Updates all
# Hook Mode: hook ID lxc/qemu pct/qm -> Updates specific ID

MODE=$1
ID=$2
TYPE=$3
CMD=$4

update_machine() {
    local id=$1
    local type=$2 # 'lxc' or 'qemu'
    local conf_cmd=$3 # 'pct' or 'qm'
    
    # Get Status
    STATUS=$($conf_cmd status $id 2>/dev/null | awk '{print $2}')
    if [ "$STATUS" != "running" ]; then
         [ "$MODE" == "hook" ] && return
         return
    fi

    # Get IP
    if [ "$type" == "lxc" ]; then
        IP=$(pct config $id 2>/dev/null | grep -oE 'ip=[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+' | head -n 1 | cut -d= -f2)
        [ -z "$IP" ] && IP=$(pct exec $id -- hostname -I 2>/dev/null | tr ' ' '\n' | grep -v '^127\.' | head -n 1)
    else
        IP=$(pvesh get /nodes/$(hostname)/qemu/$id/agent/network-get-interfaces --output-format json 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+' | grep -v '^127\.' | head -n 1)
    fi

    [ -z "$IP" ] && return

    # Get Notes
    OLD=$($conf_cmd config $id | grep '^description:' | sed 's/^description: //' | python3 -c 'import sys, urllib.parse; print(urllib.parse.unquote(sys.stdin.read()))')
    
    # Logic: Check if first line is an IP
    FIRST_LINE=$(echo "$OLD" | head -n 1)
    
    if [[ "$FIRST_LINE" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
        # First line IS an IP address
        if [ "$FIRST_LINE" == "$IP" ]; then
            # Use 'Hook Mode' silent return to avoid spamming logs if nothing changed
            [ "$MODE" != "hook" ] && echo "[ ] $type $id already has correct IP ($IP)"
        else
            # Replace the old IP (First Line) with the new one
            # We use tail -n +2 to get everything AFTER line 1, then put new IP on top
            REST_OF_NOTES=$(echo "$OLD" | tail -n +2)
            NEW_NOTES=$(printf "$IP\n$REST_OF_NOTES")
            
            pvesh set /nodes/$(hostname)/$type/$id/config --description "$NEW_NOTES" >/dev/null 2>&1
            echo "[✓] Updated $type $id IP: $FIRST_LINE -> $IP"
        fi
    else
        # First line is NOT an IP (Normal text)
        if ! echo "$OLD" | grep -q "$IP"; then
            # Prepend IP since it's missing entirely
            pvesh set /nodes/$(hostname)/$type/$id/config --description "$(printf "$IP\n\n$OLD")" >/dev/null 2>&1
            echo "[✓] Added IP $IP to $type $id"
        else
             [ "$MODE" != "hook" ] && echo "[ ] $type $id IP present in notes"
        fi
    fi
}

# --- MAIN LOGIC ---

if [ "$MODE" == "hook" ]; then
    update_machine $ID $TYPE $CMD
else
    echo -e "\n\033[1;36m>>> Updating Proxmox Node Notes <<<\033[0m"
    echo -e "\n\033[1;34m[LXC Containers]\033[0m"
    for id in $(pct list 2>/dev/null | awk 'NR>1 {print $1}'); do update_machine $id "lxc" "pct"; done
    
    echo -e "\n\033[1;35m[Virtual Machines]\033[0m"
    for id in $(qm list 2>/dev/null | awk 'NR>1 {print $1}'); do update_machine $id "qemu" "qm"; done
    echo -e "\n\033[1;36m>>> Update Complete <<<\033[0m\n"
fi
